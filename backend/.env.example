# ===================================
# ĐẤT VIỆT CORE - ENV TEMPLATE
# Land Management System Configuration
# ===================================
# Copy this file to .env and fill in your actual values

# ===================================
# SERVER CONFIGURATION
# ===================================
PORT=5000
NODE_ENV=development

# ===================================
# DATABASE
# ===================================
MONGO_URI=mongodb://localhost:27017/SoTayQuanLyDat

# ===================================
# JWT AUTHENTICATION
# ===================================
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRE=30d

# ===================================
# GOOGLE OAUTH
# ===================================
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
SERVER_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173

# ===================================
# EMAIL CONFIGURATION (GMAIL SMTP)
# ===================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
FROM_NAME=Hệ thống Quản lý Đất đai
FROM_EMAIL=noreply@datvietcore.gov.vn

# ===================================
# CLOUDINARY (FILE STORAGE)
# ===================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ===================================
# SETUP INSTRUCTIONS
# ===================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in all the values above with your actual credentials
# 3. Never commit the .env file to git (it's in .gitignore)
# 4. For production, use environment variables or secure secret management
# ===================================
# KEEP THESE FILES (NEGATION RULES)
# ===================================
# Keep important config files
!.gitignore
!.gitkeep
!README.md
!package.json
!.env.example

# Keep essential directories
!public/
!src/
!config/
!routes/
!models/
!controllers/
!middleware/
!utils/

# Keep documentation
!docs/
!*.md